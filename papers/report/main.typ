      columns: 3,
      table.header[ชนิดของคำถาม][จำนวนทั้งหมด][จำนวนที่เครื่องตอบถูก],
      [คำถามจริง], [19], [16],
      [คำถามเท็จ], [11], [7],
      [รวม], [30], [23],
    ),
